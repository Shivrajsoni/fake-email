{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id,\n               from_address,\n               subject,\n               received_at,\n               LEFT(COALESCE(body_plain, body_html), 120) AS preview\n        FROM received_emails\n        WHERE temp_email_id = $1\n        ORDER BY received_at DESC\n        LIMIT $2 OFFSET $3\n        ",
