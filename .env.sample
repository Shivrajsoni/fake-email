# Optional: map Postgres to a host port if 5433 is taken (containers still use postgres:5432).
# POSTGRES_HOST_PORT=5433

DOMAIN=mg.erite.xyz
PORT=3001
SMTP_PORT=25
DB_MAX_CONNECTIONS=2
# Empty all tables on this interval (seconds). 86400 = daily. 0 = disabled.
EPHEMERAL_DB_RESET_INTERVAL_SECS=86400